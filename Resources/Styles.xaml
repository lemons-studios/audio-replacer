<?xml version="1.0" encoding="utf-8" ?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:communityToolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="TextBlock" x:Key="TitleText">
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4.5" />
    </Style>

    <Style
        BasedOn="{StaticResource BaseButton}"
        TargetType="Button"
        x:Key="AccentButton">
        <Setter Property="Background" Value="{ThemeResource SystemControlHighlightAccentBrush}" />
    </Style>

    <Style TargetType="TextBlock" x:Key="FileCounter">
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style TargetType="Button" x:Key="BaseButton">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinWidth" Value="110" />
    </Style>

    <Style
        BasedOn="{StaticResource AccentButton}"
        TargetType="Button"
        x:Key="OperationButton">
        <Setter Property="Margin" Value="20,0" />
    </Style>

    <Style TargetType="Button" x:Key="RegularButton">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinWidth" Value="110" />
    </Style>

    <Style TargetType="MediaPlayerElement" x:Key="AudioPlayer">
        <Setter Property="MaxHeight" Value="75" />
        <Setter Property="MaxWidth" Value="650" />
        <Setter Property="AreTransportControlsEnabled" Value="True" />
        <Setter Property="AutoPlay" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{ThemeResource LayerOnMicaBaseAltFillColorTertiaryBrush}" />
        <Setter Property="Margin" Value="0,-5" />
    </Style>

    <Style TargetType="Border" x:Key="PanelCard">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorAltBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="1.5" />
    </Style>

    <Style TargetType="TextBlock" x:Key="TitleBarText">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="7.5,0,0,0" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="Light" />
    </Style>

    <Style TargetType="FontIcon" x:Key="TitleBarIcon">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="5,0,2.5,0" />
    </Style>

    <Style TargetType="ComboBox" x:Key="DropdownMenu">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="MaxDropDownHeight" Value="285" />
        <Setter Property="Width" Value="210" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style TargetType="InfoBar" x:Key="ToastNotification">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,20,0,15" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style TargetType="communityToolkit:SettingsCard" x:Key="SettingsCardStyle">
        <Setter Property="Margin" Value="0,0,0,7.5" />
    </Style>

    <Style TargetType="ScrollViewer" x:Key="SettingsScroll">
        <Setter Property="ZoomMode" Value="Disabled" />
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="IsVerticalScrollChainingEnabled" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="HorizontalScrollMode" Value="Disabled" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollMode" Value="Enabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
    </Style>
</ResourceDictionary>